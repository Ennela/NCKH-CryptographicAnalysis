# ==============================================================================
# Environment Configuration Template
# Copy this file to .env and configure local values. DO NOT commit actual secrets.
# ==============================================================================

# General
ENV=development # development | production | test
DEBUG=true

# Database (PostgreSQL + TimescaleDB)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secure_pass_123
POSTGRES_DB=stock_crypto_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Sync URL (psycopg2) — dùng cho Alembic + backward-compat
DATABASE_URL=postgresql+psycopg2://postgres:postgres_secure_pass_123@postgres:5432/stock_crypto_db
# Async URL (asyncpg) — dùng cho FastAPI async session
DATABASE_URL_ASYNC=postgresql+asyncpg://postgres:postgres_secure_pass_123@postgres:5432/stock_crypto_db

# Redis & Celery
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# MLflow Tracking Server
MLFLOW_TRACKING_URI=http://mlflow:5000

# API Security (Inference Service)
API_KEY_SECRET=generate_a_secure_long_random_string_here
RATE_LIMIT_PER_MINUTE=60

# Data Sources API (Optional for Binance public REST, required for authenticated trading/limits)
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret

# Error Tracking (Sentry)
SENTRY_DSN=https://your_sentry_dsn@o00000.ingest.sentry.io/00000
